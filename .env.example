# =========================================================================
# FINDIT PLATFORM ENVIRONMENT CONFIGURATION TEMPLATE
# Copy this file to .env and configure the variables accordingly.
# =========================================================================

# 1. Core Flask Application Settings
SECRET_KEY=dev_key_findit_9918237
DATABASE_URL=findit.db
DEBUG=True

# 2. SMTP Mail Server Settings (For Email OTP and Match Notifications)
# If omitted or SMTP credentials fail, the application falls back to "Development Mode",
# printing all generated OTPs and email contents directly to the server terminal console 
# and the local log file (backend/logs/emails_sent.log) instead of crashing.
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password

# 3. Optional Services (Cloudinary Cloud Storage configuration if active)
CLOUDINARY_URL=
